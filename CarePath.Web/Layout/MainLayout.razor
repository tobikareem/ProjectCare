@inherits LayoutComponentBase
@using System.Security.Claims
@inject TokenAuthenticationStateProvider AuthState
@inject NavigationManager Navigation

<a class="skip-link" href="#main-content">Skip to main content</a>

<header class="prototype-bar">
    <div>
        <strong>CarePath Health — Product Wireframe</strong>
        <p>Interactive concept — no real patient data</p>
    </div>
    <div class="view-switcher" aria-label="Prototype view">
        <button type="button" aria-selected="true">Web operations</button>
        <button type="button" aria-selected="false">Caregiver mobile</button>
    </div>
</header>

<div class="web-app">
    <aside class="sidebar" aria-label="Primary navigation">
        <NavMenu />
    </aside>

    <div class="desktop-main">
        <header class="topbar">
            <form class="search" role="search" @onsubmit="OnSearchSubmit" @onsubmit:preventDefault="true">
                <label for="global-search">Search caregivers, clients, shifts, or invoices</label>
                <input id="global-search" type="search" placeholder="Search caregivers, clients, shifts, invoices..." />
            </form>
            <div class="user-menu">
                <AuthorizeView>
                    <Authorized>
                        <div class="avatar" aria-hidden="true">@Initials(context.User.Identity?.Name)</div>
                        <div>
                            <strong>@context.User.Identity?.Name</strong>
                            <span class="meta">@RoleLabel(context.User)</span>
                        </div>
                        <button class="text-link user-signout" type="button" @onclick="SignOut">Sign out</button>
                    </Authorized>
                </AuthorizeView>
            </div>
        </header>

        <main id="main-content" class="web-page">
            @Body
        </main>
    </div>
</div>

@code {
    private static void OnSearchSubmit()
    {
    }

    private void SignOut()
    {
        AuthState.SignOut();
        Navigation.NavigateTo("login");
    }

    private static string RoleLabel(ClaimsPrincipal user) =>
        user.FindFirst(ClaimTypes.Role)?.Value ?? string.Empty;

    private static string Initials(string? displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName))
        {
            return "?";
        }

        var parts = displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return parts.Length >= 2
            ? string.Concat(char.ToUpperInvariant(parts[0][0]), char.ToUpperInvariant(parts[^1][0]))
            : char.ToUpperInvariant(parts[0][0]).ToString();
    }
}
