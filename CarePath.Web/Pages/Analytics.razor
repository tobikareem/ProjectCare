@page "/analytics"
@attribute [Authorize(Roles = "Admin")]
@using System.Globalization
@using CarePath.Client.Api
@using CarePath.Client.UI.Components
@using CarePath.Contracts.Billing
@using CarePath.Contracts.Common
@using CarePath.Contracts.Enumerations
@using static CarePath.Web.Shared.BusinessFormatting
@inject BillingClient Billing

<PageTitle>Analytics</PageTitle>

<div class="page-heading">
    <div>
        <p class="eyebrow">Business</p>
        <h1>Analytics</h1>
        <p class="subtle">@_periodLabel &middot; Month-to-date performance</p>
    </div>
    <button class="button button-secondary" type="button" disabled title="Coming soon"
            aria-label="Export report (coming soon)">&#8595; Export report</button>
</div>

@if (_summaryError is not null)
{
    <ApiErrorAlert Response="_summaryError" />
}

@if (_summaryLoading)
{
    <div class="analytics-grid" role="status" aria-label="Loading margin summary">
        @for (var i = 0; i < 3; i++)
        {
            <article class="card analytics-skeleton-card">
                <span class="metric-label">Loading</span>
                <div class="analytics-skeleton analytics-skeleton-value"></div>
                <div class="analytics-skeleton analytics-skeleton-line"></div>
                <div class="bar-track bar-track-offset">
                    <span class="analytics-meter-fill"></span>
                </div>
            </article>
        }
    </div>
}
else if (_summary is not null)
{
    var summary = _summary;
    var hasSummaryData = summary.Overall.ShiftCount > 0;
    var amountScale = AmountScale(summary);

    <div class="analytics-grid">
        <article class="card">
            <span class="metric-label">In-home care margin</span>
            <div class="kpi-big @MarginToneClass(summary.InHomeCare.GrossMarginPercentage)">@Percent(summary.InHomeCare.GrossMarginPercentage)</div>
            <div class="analytics-card-status">
                <StatusBadge Text="@TargetText(summary.InHomeCare.GrossMarginPercentage, 40m, 45m, summary.InHomeCare.ShiftCount)" Tone="@TargetTone(summary.InHomeCare.GrossMarginPercentage, 40m, 45m, summary.InHomeCare.ShiftCount)" />
            </div>
            <span class="trend trend-muted">@summary.InHomeCare.ShiftCount shifts &middot; @Hours(summary.InHomeCare.TotalBillableHours) hrs</span>
            <div class="bar-track bar-track-offset" role="progressbar" aria-label="In-home care margin percentage"
                 aria-valuemin="0" aria-valuemax="50" aria-valuenow="@AriaPercent(summary.InHomeCare.GrossMarginPercentage)">
                <span class="analytics-meter-fill" style="@BarStyle(summary.InHomeCare.GrossMarginPercentage)"></span>
            </div>
        </article>
        <article class="card">
            <span class="metric-label">Facility staffing margin</span>
            <div class="kpi-big @MarginToneClass(summary.FacilityStaffing.GrossMarginPercentage)">@Percent(summary.FacilityStaffing.GrossMarginPercentage)</div>
            <div class="analytics-card-status">
                <StatusBadge Text="@TargetText(summary.FacilityStaffing.GrossMarginPercentage, 25m, 30m, summary.FacilityStaffing.ShiftCount)" Tone="@TargetTone(summary.FacilityStaffing.GrossMarginPercentage, 25m, 30m, summary.FacilityStaffing.ShiftCount)" />
            </div>
            <span class="trend trend-muted">@summary.FacilityStaffing.ShiftCount shifts &middot; @Hours(summary.FacilityStaffing.TotalBillableHours) hrs</span>
            <div class="bar-track bar-track-offset" role="progressbar" aria-label="Facility staffing margin percentage"
                 aria-valuemin="0" aria-valuemax="50" aria-valuenow="@AriaPercent(summary.FacilityStaffing.GrossMarginPercentage)">
                <span class="analytics-meter-fill analytics-meter-fill-staffing" style="@BarStyle(summary.FacilityStaffing.GrossMarginPercentage)"></span>
            </div>
        </article>
        <article class="card">
            <span class="metric-label">Overall margin</span>
            <div class="kpi-big @MarginToneClass(summary.Overall.GrossMarginPercentage)">@Percent(summary.Overall.GrossMarginPercentage)</div>
            <div class="analytics-card-status">
                <StatusBadge Text="@(hasSummaryData ? "Blended result" : "No completed shifts")" Tone="@(hasSummaryData ? BadgeTone.Info : BadgeTone.Neutral)" />
            </div>
            <span class="trend trend-muted">@summary.Overall.ShiftCount shifts &middot; @Hours(summary.Overall.TotalBillableHours) hrs</span>
            <div class="bar-track bar-track-offset" role="progressbar" aria-label="Overall margin percentage"
                 aria-valuemin="0" aria-valuemax="50" aria-valuenow="@AriaPercent(summary.Overall.GrossMarginPercentage)">
                <span class="analytics-meter-fill" style="@BarStyle(summary.Overall.GrossMarginPercentage)"></span>
            </div>
        </article>
    </div>

    @if (!hasSummaryData)
    {
        <p class="empty-state analytics-empty">No completed billable shifts are available for @_periodLabel.</p>
    }

    <div class="dashboard-grid">
        <div>
            <section class="card" aria-labelledby="revenue-chart-heading">
                <div class="section-header">
                    <h2 id="revenue-chart-heading">Monthly revenue trend</h2>
                </div>
                <div class="analytics-bars" aria-label="Month-to-date financial totals">
                    <div class="analytics-bar-row">
                        <header>
                            <span>Total revenue</span>
                            <strong>@Money(summary.Overall.TotalRevenue)</strong>
                        </header>
                        <div class="bar-track" role="progressbar" aria-label="Total revenue" aria-valuemin="0"
                             aria-valuemax="@AriaAmount(amountScale)" aria-valuenow="@AriaAmount(summary.Overall.TotalRevenue)">
                            <span class="analytics-meter-fill" style="@AmountBarStyle(summary.Overall.TotalRevenue, amountScale)"></span>
                        </div>
                    </div>
                    <div class="analytics-bar-row">
                        <header>
                            <span>Labor cost</span>
                            <strong>@Money(summary.Overall.TotalLaborCost)</strong>
                        </header>
                        <div class="bar-track" role="progressbar" aria-label="Labor cost" aria-valuemin="0"
                             aria-valuemax="@AriaAmount(amountScale)" aria-valuenow="@AriaAmount(summary.Overall.TotalLaborCost)">
                            <span class="analytics-meter-fill analytics-meter-fill-staffing" style="@AmountBarStyle(summary.Overall.TotalLaborCost, amountScale)"></span>
                        </div>
                    </div>
                    <div class="analytics-bar-row">
                        <header>
                            <span>Gross profit</span>
                            <strong class="@(summary.Overall.TotalGrossMargin >= 0 ? "kpi-big-positive" : "kpi-big-negative")">@Money(summary.Overall.TotalGrossMargin)</strong>
                        </header>
                        <div class="bar-track" role="progressbar" aria-label="Gross profit" aria-valuemin="0"
                             aria-valuemax="@AriaAmount(amountScale)" aria-valuenow="@AriaAmount(Math.Abs(summary.Overall.TotalGrossMargin))">
                            <span class="analytics-meter-fill @(summary.Overall.TotalGrossMargin >= 0 ? null : "analytics-meter-fill-negative")"
                                  style="@AmountBarStyle(Math.Abs(summary.Overall.TotalGrossMargin), amountScale)"></span>
                        </div>
                    </div>
                </div>
            </section>

            <section class="card section-offset" aria-labelledby="service-line-heading">
                <div class="section-header">
                    <h2 id="service-line-heading">Margin by service line</h2>
                </div>
                <div class="analytics-service-lines">
                    @foreach (var line in ServiceLines(summary))
                    {
                        <div class="analytics-service-line">
                            <div>
                                <strong>@line.Label</strong>
                                <span class="meta">@line.ShiftCount shifts &middot; @Hours(line.TotalBillableHours) hrs</span>
                            </div>
                            <div class="analytics-service-line-value">
                                <span>@Money(line.TotalGrossMargin)</span>
                                <StatusBadge Text="@Percent(line.GrossMarginPercentage)" Tone="@MarginTone(line.GrossMarginPercentage)" />
                            </div>
                            <div class="bar-track" role="progressbar" aria-label="@($"{line.Label} margin percentage")"
                                 aria-valuemin="0" aria-valuemax="50" aria-valuenow="@AriaPercent(line.GrossMarginPercentage)">
                                <span class="analytics-meter-fill @line.CssClass" style="@BarStyle(line.GrossMarginPercentage)"></span>
                            </div>
                        </div>
                    }
                </div>
            </section>
        </div>

        <aside>
            <section class="card" aria-labelledby="mtd-summary-heading">
                <h2 id="mtd-summary-heading" class="summary-heading">MTD summary</h2>
                <div class="profile-list">
                    <div class="profile-row"><span class="subtle">Total revenue</span><strong>@Money(summary.Overall.TotalRevenue)</strong></div>
                    <div class="profile-row"><span class="subtle">Labor cost</span><strong>@Money(summary.Overall.TotalLaborCost)</strong></div>
                    <div class="profile-row">
                        <span class="subtle">Gross profit</span>
                        <strong class="@(summary.Overall.TotalGrossMargin >= 0 ? "kpi-big-positive" : "kpi-big-negative")">@Money(summary.Overall.TotalGrossMargin)</strong>
                    </div>
                    <div class="profile-row"><span class="subtle">Billable hours</span><strong>@Hours(summary.Overall.TotalBillableHours) hrs</strong></div>
                    <div class="profile-row"><span class="subtle">Completed shifts</span><strong>@summary.Overall.ShiftCount</strong></div>
                    <div class="profile-row"><span class="subtle">Avg margin/hr</span><strong>@Money(summary.Overall.AverageHourlyGrossMargin)</strong></div>
                </div>
            </section>
        </aside>
    </div>
}

<section class="card section-offset" aria-labelledby="shift-margins-heading">
    <div class="section-header">
        <div>
            <h2 id="shift-margins-heading">Per-shift margins</h2>
            <span class="subtle">@_periodLabel</span>
        </div>
    </div>
    @if (_shiftError is not null)
    {
        <ApiErrorAlert Response="_shiftError" />
    }
    else
    {
        <PagedTable TItem="ShiftMarginDto"
                    Result="_shiftMargins"
                    IsLoading="_shiftLoading"
                    LoadingText="Loading shift margins..."
                    EmptyText="No completed shifts in this period."
                    PagerLabel="Shift margin pages"
                    OnPageChanged="LoadShiftMarginsAsync">
            <HeaderTemplate>
                <tr>
                    <th>Date</th>
                    <th>Service line</th>
                    <th>Hours</th>
                    <th>Bill rate</th>
                    <th>Pay rate</th>
                    <th>Margin/hr</th>
                    <th>Margin</th>
                    <th>Margin %</th>
                </tr>
            </HeaderTemplate>
            <RowTemplate Context="shift">
                <tr>
                    <td>@ShortDate(shift.ScheduledStartTime)</td>
                    <td>@ServiceLineLabel(shift.ServiceType)</td>
                    <td>@Hours(shift.BillableHours)</td>
                    <td>@Money(shift.BillRate)</td>
                    <td>@Money(shift.PayRate)</td>
                    <td>@Money(shift.HourlyGrossMargin)</td>
                    <td>@Money(shift.GrossMargin)</td>
                    <td>
                        <StatusBadge Text="@Percent(shift.GrossMarginPercentage)" Tone="@MarginTone(shift.GrossMarginPercentage)" />
                    </td>
                </tr>
            </RowTemplate>
        </PagedTable>
    }
</section>

@code {
    // TODO(PM): no revenue time-series, utilization, active caregiver/client, or no-show endpoint
    // exists. This page renders the wireframe workflow with the real Admin margin contracts only.
    private MarginSummaryDto? _summary;
    private ApiResponse? _summaryError;
    private bool _summaryLoading = true;
    private PagedResult<ShiftMarginDto>? _shiftMargins;
    private ApiResponse? _shiftError;
    private bool _shiftLoading = true;
    private DateTime _periodStartUtc;
    private DateTime _periodEndUtc;
    private string _periodLabel = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var nowUtc = DateTime.UtcNow;
        _periodStartUtc = new DateTime(nowUtc.Year, nowUtc.Month, 1, 0, 0, 0, DateTimeKind.Utc);
        _periodEndUtc = _periodStartUtc.AddMonths(1);
        _periodLabel = _periodStartUtc.ToString("MMMM yyyy", CultureInfo.InvariantCulture);

        await Task.WhenAll(LoadSummaryAsync(), LoadShiftMarginsAsync(1));
    }

    private async Task LoadSummaryAsync()
    {
        _summaryLoading = true;
        _summaryError = null;

        try
        {
            var response = await Billing.GetMarginSummaryAsync(_periodStartUtc, _periodEndUtc);
            if (response is { Success: true, Data: not null })
            {
                _summary = response.Data;
            }
            else
            {
                _summary = null;
                _summaryError = response;
            }
        }
        catch (HttpRequestException)
        {
            // PHI-safe generic failure; never surface exception details.
            _summary = null;
            _summaryError = ApiResponse.Fail(new ApiError("network.unreachable", "The server could not be reached."));
        }

        _summaryLoading = false;
    }

    private async Task LoadShiftMarginsAsync(int pageNumber)
    {
        _shiftLoading = true;
        _shiftError = null;

        try
        {
            var response = await Billing.GetShiftMarginsAsync(
                new PagedRequest { PageNumber = pageNumber }, _periodStartUtc, _periodEndUtc);
            if (response is { Success: true, Data: not null })
            {
                _shiftMargins = response.Data;
            }
            else
            {
                _shiftMargins = null;
                _shiftError = response;
            }
        }
        catch (HttpRequestException)
        {
            _shiftMargins = null;
            _shiftError = ApiResponse.Fail(new ApiError("network.unreachable", "The server could not be reached."));
        }

        _shiftLoading = false;
    }

    private static string MarginToneClass(decimal percentage) =>
        percentage >= 0 ? "kpi-big-positive" : "kpi-big-negative";

    private static BadgeTone MarginTone(decimal percentage) =>
        percentage < 0 ? BadgeTone.Danger
        : percentage == 0 ? BadgeTone.Neutral
        : BadgeTone.Success;

    private static BadgeTone TargetTone(decimal percentage, decimal targetMin, decimal targetMax, int shiftCount) =>
        shiftCount == 0 ? BadgeTone.Neutral
        : percentage < targetMin ? BadgeTone.Warning
        : percentage > targetMax ? BadgeTone.Info
        : BadgeTone.Success;

    private static string TargetText(decimal percentage, decimal targetMin, decimal targetMax, int shiftCount)
    {
        if (shiftCount == 0)
        {
            return "No completed shifts";
        }

        var target = $"target: {targetMin:0.#}-{targetMax:0.#}%";
        return percentage < targetMin ? $"Below {target}"
            : percentage > targetMax ? $"Above {target}"
            : $"Target: {targetMin:0.#}-{targetMax:0.#}%";
    }

    // The wireframe margin meters use a 0-50% scale.
    private static string BarWidth(decimal percentage) =>
        Math.Clamp(percentage * 2m, 0m, 100m).ToString("0.#", CultureInfo.InvariantCulture);

    private static string BarStyle(decimal percentage) =>
        $"--analytics-bar-width:{BarWidth(percentage)}%;";

    private static string AriaPercent(decimal percentage) =>
        Math.Clamp(percentage, 0m, 50m).ToString("0.#", CultureInfo.InvariantCulture);

    private static decimal AmountScale(MarginSummaryDto summary) =>
        new[]
        {
            summary.Overall.TotalRevenue,
            summary.Overall.TotalLaborCost,
            Math.Abs(summary.Overall.TotalGrossMargin)
        }.Max();

    private static string AmountBarStyle(decimal amount, decimal scale) =>
        $"--analytics-bar-width:{AmountBarWidth(amount, scale)}%;";

    private static string AmountBarWidth(decimal amount, decimal scale) =>
        scale <= 0m
            ? "0"
            : Math.Clamp(amount / scale * 100m, 0m, 100m).ToString("0.#", CultureInfo.InvariantCulture);

    private static string AriaAmount(decimal amount) =>
        Math.Max(amount, 0m).ToString("0.##", CultureInfo.InvariantCulture);

    private static string ServiceLineLabel(ServiceType serviceType) => serviceType switch
    {
        ServiceType.InHomeCare => "In-home care",
        ServiceType.FacilityStaffing => "Facility staffing",
        _ => serviceType.ToString()
    };

    private static IReadOnlyList<ServiceLineDisplay> ServiceLines(MarginSummaryDto summary) =>
    [
        new("In-home care", summary.InHomeCare, string.Empty),
        new("Facility staffing", summary.FacilityStaffing, "analytics-meter-fill-staffing"),
        new("Overall", summary.Overall, string.Empty)
    ];

    private sealed record ServiceLineDisplay(
        string Label,
        ServiceLineMarginDto Metrics,
        string CssClass)
    {
        public int ShiftCount => Metrics.ShiftCount;

        public decimal TotalBillableHours => Metrics.TotalBillableHours;

        public decimal TotalGrossMargin => Metrics.TotalGrossMargin;

        public decimal GrossMarginPercentage => Metrics.GrossMarginPercentage;
    }
}
