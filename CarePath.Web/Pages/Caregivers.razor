@page "/caregivers"
@using CarePath.Client.Api
@using CarePath.Client.UI.Components
@using CarePath.Contracts.Common
@using CarePath.Contracts.Enumerations
@using CarePath.Contracts.Identity
@using CarePath.Contracts.Scheduling
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Coordinator")]
@inject CaregiversClient CaregiversClient
@inject NavigationManager Navigation

<PageTitle>Caregivers</PageTitle>

<div class="page-heading">
    <div>
        <p class="eyebrow">People</p>
        <h1>Caregivers</h1>
        <p class="subtle">@CaregiverSummaryText</p>
    </div>
    <button class="button button-primary" type="button" @onclick="NavigateToCreate">+ Add caregiver</button>
</div>

<div class="filter-bar" role="search" aria-label="Caregiver filters">
    <input type="search" placeholder="Search by name..." @bind="searchTerm" @bind:event="oninput" aria-label="Search caregivers by name" />
    <select @bind="employmentFilter" aria-label="Employment type">
        <option value="">All types</option>
        <option value="@EmploymentType.W2Employee">W-2 Employee</option>
        <option value="@EmploymentType.Contractor1099">1099 Contractor</option>
    </select>
    <select @bind="statusFilter" aria-label="Status">
        <option value="">All statuses</option>
        <option value="active">Active</option>
        <option value="inactive">Inactive</option>
    </select>
</div>

@if (caregiverError is not null)
{
    <ApiErrorAlert Response="caregiverError" />
}

<div class="caregiver-workspace">
    <section class="card table-card" aria-labelledby="caregiver-roster-heading">
        <div class="section-header">
            <div>
                <h2 id="caregiver-roster-heading">Caregiver roster</h2>
                <span class="subtle">Paged from the caregiver API</span>
            </div>
            <span class="meta">@PagingText(caregiverPage)</span>
        </div>

        <PagedTable TItem="CaregiverSummaryDto"
                    Result="DisplayedCaregiverPage"
                    IsLoading="isLoading"
                    LoadingText="Loading caregivers..."
                    EmptyText="No caregivers match the current filters."
                    TableClass="data-table"
                    PagerButtonClass="button button-secondary button-sm"
                    PagerLabel="Caregiver pages"
                    PageSize="pageSize"
                    MinPageSize="DefaultPageSize"
                    EnableViewportPageSize="true"
                    ShowPagerWhenSinglePage="true"
                    OnPageChanged="LoadCaregiverPageAsync"
                    OnPageSizeChanged="ChangeCaregiverPageSizeAsync">
            <HeaderTemplate>
                <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Rating</th>
                    <th>Status</th>
                    <th>View</th>
                </tr>
            </HeaderTemplate>
            <RowTemplate Context="caregiver">
                <tr class="@(selectedCaregiverId == caregiver.Id ? "selected-row" : null)">
                    <td>
                        <span class="avatar-sm" aria-hidden="true">@Initials(caregiver.FullName)</span>
                        <strong>@caregiver.FullName</strong>
                        <span class="meta">User @ShortId(caregiver.UserId)</span>
                    </td>
                    <td>@FormatEmploymentType(caregiver.EmploymentType)</td>
                    <td>@FormatRating(caregiver.AverageRating)</td>
                    <td>
                        <StatusBadge Text="@(caregiver.IsActive ? "Active" : "Inactive")"
                                     Tone="@(caregiver.IsActive ? BadgeTone.Success : BadgeTone.Neutral)" />
                    </td>
                    <td>
                        <button class="text-link" type="button" @onclick="() => SelectCaregiverAsync(caregiver.Id)">View</button>
                    </td>
                </tr>
            </RowTemplate>
        </PagedTable>
    </section>

    <aside class="card profile-panel" aria-labelledby="caregiver-profile-heading">
        <div class="section-header">
            <div>
                <h2 id="caregiver-profile-heading">Profile detail</h2>
                <span class="subtle">Skills, credentials, and performance</span>
            </div>
        </div>

        @if (caregiverDetailError is not null)
        {
            <ApiErrorAlert Response="caregiverDetailError" />
        }
        else if (isDetailLoading)
        {
            <p class="empty-state">Loading caregiver profile...</p>
        }
        else if (selectedCaregiver is null)
        {
            <p class="empty-state">Select a caregiver to view skills and certifications.</p>
        }
        else
        {
            <div class="profile-header">
                <div class="profile-identity">
                    <span class="avatar-lg" aria-hidden="true">@Initials(selectedCaregiver.FullName)</span>
                    <div>
                        <strong>@selectedCaregiver.FullName</strong>
                        <span class="meta">@FormatEmploymentType(selectedCaregiver.EmploymentType) - @AvailabilityText(selectedCaregiver)</span>
                    </div>
                </div>
                <StatusBadge Text="@(selectedCaregiver.IsActive ? "Active" : "Inactive")"
                             Tone="@(selectedCaregiver.IsActive ? BadgeTone.Success : BadgeTone.Neutral)" />
            </div>

            <section aria-labelledby="profile-contact-heading">
                <h3 id="profile-contact-heading">Contact</h3>
                <div class="profile-row"><span class="subtle">Email</span><span>@selectedCaregiver.Email</span></div>
                <div class="profile-row"><span class="subtle">Phone</span><span>@selectedCaregiver.PhoneNumber</span></div>
            </section>

            <section aria-labelledby="profile-employment-heading">
                <h3 id="profile-employment-heading">Employment and availability</h3>
                <div class="profile-row"><span class="subtle">Hire date</span><span>@selectedCaregiver.HireDate.ToLocalTime().ToString("MMM d, yyyy")</span></div>
                <div class="profile-row"><span class="subtle">Pay rate</span><span>@selectedCaregiver.HourlyPayRate.ToString("C")/hr</span></div>
                <div class="profile-row"><span class="subtle">Max weekly hours</span><span>@selectedCaregiver.MaxWeeklyHours</span></div>
                <div class="profile-row"><span class="subtle">Availability</span><span>@AvailabilityText(selectedCaregiver)</span></div>
            </section>

            <section aria-labelledby="profile-skills-heading">
                <h3 id="profile-skills-heading">Skills</h3>
                <div class="badge-row">
                    @foreach (var skill in CaregiverSkills(selectedCaregiver))
                    {
                        <StatusBadge Text="@skill" Tone="@BadgeTone.Info" />
                    }
                    @if (CaregiverSkills(selectedCaregiver).Count == 0)
                    {
                        <span class="subtle">No specialty skills recorded.</span>
                    }
                </div>
            </section>

            <section aria-labelledby="profile-certs-heading">
                <div class="section-header compact-header">
                    <h3 id="profile-certs-heading">Certifications</h3>
                    <button class="text-link" type="button" @onclick="NavigateToCertification">Add certification</button>
                </div>
                <div class="stacked-list">
                    @if (selectedCaregiver.Certifications.Count == 0)
                    {
                        <p class="empty-state compact">No certifications recorded.</p>
                    }
                    else
                    {
                        @foreach (var certification in selectedCaregiver.Certifications)
                        {
                            <div class="credential-row">
                                <div>
                                    <strong>@FormatCertificationType(certification.Type)</strong>
                                    <span class="meta">@certification.IssuingAuthority - expires @certification.ExpirationDate.ToLocalTime().ToString("MMM d, yyyy")</span>
                                </div>
                                <StatusBadge Text="@CertificationStatusText(certification)" Tone="@CertificationTone(certification)" />
                            </div>
                        }
                    }
                </div>
            </section>

            <section aria-labelledby="profile-performance-heading">
                <h3 id="profile-performance-heading">Performance</h3>
                <div class="profile-row"><span class="subtle">Average rating</span><span>@FormatRating(selectedCaregiver.AverageRating)</span></div>
                <div class="profile-row"><span class="subtle">Shifts (MTD)</span><span>@selectedCaregiver.ShiftsMtd checked in</span></div>
                <div class="profile-row"><span class="subtle">Billable hours (MTD)</span><span>@selectedCaregiver.BillableHoursMtd.ToString("0.##") hrs</span></div>
                <div class="profile-row"><span class="subtle">Completed shifts</span><span>@selectedCaregiver.TotalShiftsCompleted lifetime</span></div>
                <div class="profile-row"><span class="subtle">No-shows</span><span>@selectedCaregiver.NoShowCount</span></div>
            </section>

            <section aria-labelledby="profile-client-history-heading">
                <div class="section-header compact-header">
                    <div><h3 id="profile-client-history-heading">Recent client assignments</h3><span class="subtle">Latest @clientPreview?.Items.Count of @clientPreview?.TotalCount relationships</span></div>
                    <button class="text-link" type="button" @onclick="NavigateToClientHistory">View all</button>
                </div>
                @if (assignmentPreviewError is not null)
                {
                    <ApiErrorAlert Response="assignmentPreviewError" />
                }
                else if (clientPreview is null)
                {
                    <p class="empty-state compact">Loading client assignments...</p>
                }
                else if (clientPreview.Items.Count == 0)
                {
                    <p class="empty-state compact">No client assignments found.</p>
                }
                else
                {
                    <div class="stacked-list">
                        @foreach (var assignment in clientPreview.Items)
                        {
                            <div class="credential-row">
                                <div><strong>@assignment.ClientDisplayName</strong><span class="meta">@assignment.FirstAssignedAtUtc.ToLocalTime().ToString("MMM d, yyyy") – @(assignment.Status == AssignmentRelationshipStatus.Current ? "Present" : assignment.LastAssignedAtUtc.ToLocalTime().ToString("MMM d, yyyy")) · @assignment.CompletedShiftCount completed</span></div>
                                <StatusBadge Text="@assignment.Status.ToString()" Tone="@(assignment.Status == AssignmentRelationshipStatus.Current ? BadgeTone.Success : BadgeTone.Info)" />
                            </div>
                        }
                    </div>
                }
            </section>

            <div class="access-action-row">
                <button class="button button-primary" type="button" @onclick="NavigateToEligibleShifts">Schedule eligible shifts</button>
                <button class="button button-secondary" type="button" @onclick="NavigateToSchedule">Open schedule</button>
            </div>
        }
    </aside>
</div>

@code {
    private const int DefaultPageSize = 5;

    private PagedResult<CaregiverSummaryDto>? caregiverPage;
    private ApiResponse? caregiverError;
    private ApiResponse? caregiverDetailError;
    private ApiResponse? assignmentPreviewError;
    private CaregiverDetailDto? selectedCaregiver;
    private PagedResult<ClientAssignmentSummaryDto>? clientPreview;
    private Guid? selectedCaregiverId;
    private bool isLoading;
    private bool isDetailLoading;
    private int pageNumber = 1;
    private int pageSize = DefaultPageSize;
    private string searchTerm = string.Empty;
    private string employmentFilter = string.Empty;
    private string statusFilter = string.Empty;

    private IReadOnlyList<CaregiverSummaryDto> FilteredCaregivers =>
        caregiverPage?.Items.Where(MatchesFilters).ToArray() ?? [];

    private PagedResult<CaregiverSummaryDto>? DisplayedCaregiverPage =>
        caregiverPage is null
            ? null
            : new PagedResult<CaregiverSummaryDto>
            {
                Items = FilteredCaregivers,
                PageNumber = caregiverPage.PageNumber,
                PageSize = caregiverPage.PageSize,
                TotalCount = caregiverPage.TotalCount
            };

    private string CaregiverSummaryText
    {
        get
        {
            var items = caregiverPage?.Items ?? [];
            var active = items.Count(c => c.IsActive);
            var inactive = items.Count(c => !c.IsActive);
            return caregiverPage is null
                ? "Loading roster..."
                : $"{active} active · {inactive} inactive · {caregiverPage.TotalCount} total";
        }
    }

    protected override async Task OnInitializedAsync() => await LoadCaregiversAsync();

    private async Task LoadCaregiversAsync()
    {
        isLoading = true;
        caregiverError = null;

        var response = await CaregiversClient.GetPageAsync(new PagedRequest { PageNumber = pageNumber, PageSize = pageSize });
        if (response.Success && response.Data is not null)
        {
            caregiverPage = response.Data;
        }
        else
        {
            caregiverError = response;
        }

        isLoading = false;
    }

    private async Task SelectCaregiverAsync(Guid caregiverId)
    {
        selectedCaregiverId = caregiverId;
        selectedCaregiver = null;
        clientPreview = null;
        caregiverDetailError = null;
        assignmentPreviewError = null;
        isDetailLoading = true;

        var response = await CaregiversClient.GetAsync(caregiverId);
        if (response.Success && response.Data is not null)
        {
            selectedCaregiver = response.Data;
            var previewResponse = await CaregiversClient.SearchClientAssignmentsAsync(caregiverId, new AssignmentHistorySearchRequest { PageNumber = 1, PageSize = 2 });
            if (previewResponse.Success && previewResponse.Data is not null)
            {
                clientPreview = previewResponse.Data;
            }
            else
            {
                assignmentPreviewError = previewResponse;
            }
        }
        else
        {
            caregiverDetailError = response;
        }

        isDetailLoading = false;
    }

    private async Task LoadCaregiverPageAsync(int requestedPageNumber)
    {
        if (requestedPageNumber < 1 || requestedPageNumber == pageNumber)
        {
            return;
        }

        pageNumber = requestedPageNumber;
        ClearSelection();
        await LoadCaregiversAsync();
    }

    private async Task ChangeCaregiverPageSizeAsync(int requestedPageSize)
    {
        if (requestedPageSize < DefaultPageSize || requestedPageSize == pageSize)
        {
            return;
        }

        pageSize = requestedPageSize;
        pageNumber = 1;
        ClearSelection();
        await LoadCaregiversAsync();
    }

    private bool MatchesFilters(CaregiverSummaryDto caregiver)
    {
        if (!string.IsNullOrWhiteSpace(searchTerm)
            && !caregiver.FullName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(employmentFilter)
            && caregiver.EmploymentType.ToString() != employmentFilter)
        {
            return false;
        }

        return statusFilter switch
        {
            "active" => caregiver.IsActive,
            "inactive" => !caregiver.IsActive,
            _ => true
        };
    }

    private void ClearSelection()
    {
        selectedCaregiverId = null;
        selectedCaregiver = null;
        caregiverDetailError = null;
        assignmentPreviewError = null;
        clientPreview = null;
    }

    private void NavigateToCreate() => Navigation.NavigateTo("/caregivers/create");

    private void NavigateToCertification()
    {
        if (selectedCaregiver is not null)
        {
            Navigation.NavigateTo($"/caregivers/{selectedCaregiver.Id}/certifications");
        }
    }

    private void NavigateToEligibleShifts()
    {
        if (selectedCaregiver is not null)
        {
            Navigation.NavigateTo($"/caregivers/{selectedCaregiver.Id}/eligible-shifts");
        }
    }

    private void NavigateToSchedule() => Navigation.NavigateTo("/schedule");

    private void NavigateToClientHistory()
    {
        if (selectedCaregiverId.HasValue)
        {
            Navigation.NavigateTo($"/caregivers/{selectedCaregiverId.Value}/client-assignments");
        }
    }

    private static string PagingText<T>(PagedResult<T>? page) =>
        page is null ? "Page 1" : $"Page {page.PageNumber} of {Math.Max(page.TotalPages, 1)}";

    private static string Initials(string fullName)
    {
        var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return string.Concat(parts.Take(2).Select(part => char.ToUpperInvariant(part[0])));
    }

    private static string ShortId(Guid id) => id.ToString("N")[..8];

    private static string FormatRating(decimal? rating) =>
        rating.HasValue ? $"{rating.Value:0.0} / 5" : "Not rated";

    private static string FormatEmploymentType(EmploymentType type) => type switch
    {
        EmploymentType.W2Employee => "W-2 Employee",
        EmploymentType.Contractor1099 => "1099 Contractor",
        _ => type.ToString()
    };

    private static string FormatCertificationType(CertificationType type) => type switch
    {
        CertificationType.FirstAid => "First Aid",
        CertificationType.Alzheimers => "Alzheimer's",
        _ => type.ToString()
    };

    private static string AvailabilityText(CaregiverDetailDto caregiver)
    {
        var values = new List<string>();
        if (caregiver.AvailableWeekdays)
        {
            values.Add("weekdays");
        }

        if (caregiver.AvailableWeekends)
        {
            values.Add("weekends");
        }

        if (caregiver.AvailableNights)
        {
            values.Add("nights");
        }

        return values.Count == 0 ? "availability not set" : string.Join(", ", values);
    }

    private static IReadOnlyList<string> CaregiverSkills(CaregiverDetailDto caregiver)
    {
        var skills = new List<string>();
        if (caregiver.HasDementiaCare)
        {
            skills.Add("Dementia");
        }

        if (caregiver.HasAlzheimersCare)
        {
            skills.Add("Alzheimer's");
        }

        if (caregiver.HasMobilityAssistance)
        {
            skills.Add("Mobility");
        }

        if (caregiver.HasMedicationManagement)
        {
            skills.Add("Medication");
        }

        return skills;
    }

    private static string CertificationStatusText(CertificationDto certification)
    {
        if (certification.IsExpired)
        {
            return "Expired";
        }

        return certification.IsExpiringSoon ? "Expiring soon" : "Valid";
    }

    private static BadgeTone CertificationTone(CertificationDto certification)
    {
        if (certification.IsExpired)
        {
            return BadgeTone.Danger;
        }

        return certification.IsExpiringSoon ? BadgeTone.Warning : BadgeTone.Success;
    }
}
