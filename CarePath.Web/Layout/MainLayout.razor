@inherits LayoutComponentBase

<a class="skip-link" href="#main-content">Skip to main content</a>

<header class="prototype-bar">
    <div>
        <strong>CarePath Health — Product Wireframe</strong>
        <p>Interactive concept — no real patient data</p>
    </div>
    <div class="view-switcher" aria-label="Prototype view">
        <button type="button" aria-selected="true">Web operations</button>
        <button type="button" aria-selected="false">Caregiver mobile</button>
    </div>
</header>

<div class="web-app">
    <aside class="sidebar" aria-label="Primary navigation">
        <NavMenu />
    </aside>

    <div class="desktop-main">
        <header class="topbar">
            <form class="search" role="search" @onsubmit="OnSearchSubmit" @onsubmit:preventDefault="true">
                <label for="global-search">Search caregivers, clients, shifts, or invoices</label>
                <input id="global-search" type="search" placeholder="Search caregivers, clients, shifts, invoices..." />
            </form>
            <div class="user-menu">
                <div class="avatar" aria-hidden="true">TK</div>
                <div>
                    <strong>Tobi Kareem</strong>
                    <span class="meta">Administrator</span>
                </div>
            </div>
        </header>

        <main id="main-content" class="web-page">
            @Body
        </main>
    </div>
</div>

@code {
    private static void OnSearchSubmit()
    {
    }
}
