@using System.Security.Claims

<a class="brand" href="">
    <span class="brand-mark" aria-hidden="true">CP</span>
    <span>
        <strong>CarePath Health</strong>
        <AuthorizeView>
            <Authorized Context="brandContext">
                <span>@BrandSubtitle(brandContext.User)</span>
            </Authorized>
            <NotAuthorized>
                <span>Secure portal</span>
            </NotAuthorized>
        </AuthorizeView>
    </span>
</a>

<AuthorizeView Roles="Admin,Coordinator,Clinician">
    <Authorized>
        <p class="nav-label">Workspace</p>
        <nav class="side-nav" aria-label="Workspace navigation">
            <AuthorizeView Roles="Admin,Coordinator">
                <Authorized Context="operationsContext">
                    <NavLink href="" Match="NavLinkMatch.All">
                        <span aria-hidden="true">&#x2302;</span><span>Overview</span>
                    </NavLink>
                    <NavLink href="schedule">
                        <span aria-hidden="true">&#x25A6;</span><span>Schedule</span>
                    </NavLink>
                    <NavLink href="caregivers">
                        <span aria-hidden="true">&#x2659;</span><span>Caregivers</span>
                    </NavLink>
                </Authorized>
            </AuthorizeView>
            <NavLink href="clients">
                <span aria-hidden="true">&#x2661;</span><span>Clients</span>
            </NavLink>
            <NavLink href="visit-notes">
                <span aria-hidden="true">&#x25A4;</span><span>Visit notes</span>
            </NavLink>
        </nav>

        <AuthorizeView Roles="Admin,Coordinator">
            <Authorized Context="businessContext">
                <p class="nav-label">Business</p>
                <nav class="side-nav" aria-label="Business navigation">
                    <NavLink href="billing"><span aria-hidden="true">$</span><span>Billing</span></NavLink>
                    <AuthorizeView Roles="Admin">
                        <Authorized Context="analyticsContext">
                            <NavLink href="analytics"><span aria-hidden="true">&#x2197;</span><span>Analytics</span></NavLink>
                        </Authorized>
                    </AuthorizeView>
                    <NavLink href="compliance"><span aria-hidden="true">&#x2713;</span><span>Compliance</span></NavLink>
                </nav>
            </Authorized>
        </AuthorizeView>
    </Authorized>
</AuthorizeView>

@code {
    private static string BrandSubtitle(ClaimsPrincipal user)
    {
        if (user.IsInRole("Admin") || user.IsInRole("Coordinator") || user.IsInRole("Clinician"))
        {
            return "Admin Portal";
        }

        if (user.IsInRole("Caregiver"))
        {
            return "Caregiver Workspace";
        }

        return user.IsInRole("Client") ? "Client Portal" : "Secure portal";
    }
}

<AuthorizeView Roles="Caregiver">
    <Authorized>
        <p class="nav-label">Caregiver workspace</p>
        <nav class="side-nav" aria-label="Caregiver navigation">
            <NavLink href="my-clients"><span aria-hidden="true">&#x2661;</span><span>My clients</span></NavLink>
        </nav>
    </Authorized>
</AuthorizeView>

<AuthorizeView Roles="Client">
    <Authorized>
        <p class="nav-label">My care</p>
        <nav class="side-nav" aria-label="Client navigation">
            <NavLink href="my-caregivers"><span aria-hidden="true">&#x2661;</span><span>My caregivers</span></NavLink>
        </nav>
    </Authorized>
</AuthorizeView>

<AuthorizeView Roles="Admin">
    <Authorized>
        <p class="nav-label">Admin</p>
        <nav class="side-nav" aria-label="Admin navigation">
            <NavLink href="admin/users">
                <span aria-hidden="true">@@</span><span>User management</span>
            </NavLink>
        </nav>
    </Authorized>
</AuthorizeView>

<AuthorizeView Roles="Admin,Coordinator,Clinician">
    <Authorized Context="transitionsContext">
        <p class="nav-label">Transitions</p>
        <nav class="side-nav" aria-label="Transitions navigation">
            <NavLink href="transitions">
                <span aria-hidden="true">&#x21BB;</span><span>Dashboard</span>
            </NavLink>
            <AuthorizeView Roles="Admin,Coordinator">
                <Authorized Context="coordinatorContext">
                    <NavLink href="transitions/upload">
                        <span aria-hidden="true">&#x2191;</span><span>Upload doc</span>
                    </NavLink>
                    <NavLink href="transitions/escalations">
                        <span aria-hidden="true">!</span><span>Escalations</span>
                    </NavLink>
                </Authorized>
            </AuthorizeView>
            <AuthorizeView Roles="Admin,Clinician">
                <Authorized Context="clinicianContext">
                    <NavLink href="transitions/review">
                        <span aria-hidden="true">&#x25C7;</span><span>Review queue</span>
                    </NavLink>
                </Authorized>
            </AuthorizeView>
        </nav>
    </Authorized>
</AuthorizeView>
